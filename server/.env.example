PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/fairsight-ai
MONGO_TIMEOUT_MS=3000
DB_REQUIRED=false
JWT_SECRET=replace-this-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TIMEOUT_MS=12000
GEMINI_ALERT_WEBHOOK_URL=
GOOGLE_OAUTH_CLIENT_ID=
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_TIMEOUT_MS=4000
ML_ALLOW_MOCK_FALLBACK=true
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
# dataset storage: local | gcs
DATASET_STORAGE_PROVIDER=local
GCS_PROJECT_ID=
GCS_BUCKET_NAME=
GCS_KEY_FILENAME=
GCS_DATASET_PREFIX=datasets
