# Copy to .env and fill in. Vertex uses GOOGLE_APPLICATION_CREDENTIALS or inline service account fields.

NODE_ENV=development
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.0-flash
USE_VERTEX_INFERENCE=true

# When true, /predict returns a deterministic stub if Vertex fails (recommended for local dev).
# Set false in production only if every prediction must be model-backed.
ALLOW_DETERMINISTIC_FALLBACK=true

GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_PRIVATE_KEY_ID=
GOOGLE_CLOUD_PRIVATE_KEY=
GOOGLE_CLOUD_CLIENT_EMAIL=
GOOGLE_CLOUD_CLIENT_ID=
